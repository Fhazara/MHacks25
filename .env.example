# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Discord ───────────────────────────────────────────────────────────────────
# Create a new webhook: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook_id>/<token>

# Optional: minimum seconds between Discord messages (default: 3)
DISCORD_MIN_INTERVAL_SECONDS=3.0

# ── Agent seed phrases ────────────────────────────────────────────────────────
# Generate strong seeds with:
#   python -c "import secrets; print(secrets.token_hex(32))"
COMPLIANCE_AGENT_SEED=<random-hex-64-chars>
REQUEST_AGENT_SEED=<random-hex-64-chars>
CLIENT_AGENT_SEED=<random-hex-64-chars>

# ── Agent ports & endpoints (optional – defaults shown) ──────────────────────
COMPLIANCE_AGENT_PORT=8000
COMPLIANCE_AGENT_ENDPOINT=http://127.0.0.1:8000/submit

REQUEST_AGENT_PORT=8001
REQUEST_AGENT_ENDPOINT=http://127.0.0.1:8001/submit

CLIENT_AGENT_PORT=8003

# ── On-chain / network agent addresses ───────────────────────────────────────
# These are discovered at runtime from agent startup logs.
# Override here if running against a deployed Agentverse instance.
# REQUEST_AGENT_ADDRESS=agent1q...
# COMPLIANCE_ADDRESS=agent1q...

# ── Object detection ──────────────────────────────────────────────────────────
CAMERA_INDEX=1
# MODEL_PATH=object_detection/models/best_yolo11m.pt
# MIN_FRAMES=10
